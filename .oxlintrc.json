{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "plugins": ["import"],
  "rules": {
    "import/no-default-export": "error"
  },
  "options": {
    "typeAware": true
  },
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**"
  ],
  "overrides": [
    {
      "files": ["drizzle.config.ts"],
      "rules": {
        "import/no-default-export": "off"
      }
    }
  ]
}