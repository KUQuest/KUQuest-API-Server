{
  "name": "kuquest-api-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:local": "bash scripts/dev-local.sh",
    "start": "bun src/index.ts",
    "tunnel": "bash scripts/dev-tunnel.sh",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check": "bun run lint && bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "@elysiajs/cors": "^1.4.2",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "latest"
  }
}
