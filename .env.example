NODE_ENV=development
API_PORT=5000

# Docker publishes PostgreSQL only on loopback for optional debugging access.
POSTGRES_DB=kuquest
KUQUEST_TEST_DB=kuquest_test
POSTGRES_PORT=5432

# Bootstrap administrator is used only by the official PostgreSQL entrypoint.
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres-local-admin-only

# Role names are intentionally fixed: kuquest_migrator owns schema objects and
# kuquest_app is the restricted API role. Configure passwords, not role names.
KUQUEST_MIGRATOR_PASSWORD=migrator-local-only
KUQUEST_APP_PASSWORD=app-local-only

# Keep these URLs synchronized with the credentials above. URL-encode special
# characters used in passwords.
KUQUEST_MIGRATOR_DATABASE_URL=postgresql://kuquest_migrator:migrator-local-only@postgres:5432/kuquest
KUQUEST_APP_DATABASE_URL=postgresql://kuquest_app:app-local-only@postgres:5432/kuquest
KUQUEST_MIGRATOR_TEST_DATABASE_URL=postgresql://kuquest_migrator:migrator-local-only@postgres:5432/kuquest_test
KUQUEST_APP_TEST_DATABASE_URL=postgresql://kuquest_app:app-local-only@postgres:5432/kuquest_test

BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
# Public HTTPS URL from `bun run tunnel`; used only for provider callback setup.
PUBLIC_API_URL=

CMS_ORIGIN=http://localhost:3000
